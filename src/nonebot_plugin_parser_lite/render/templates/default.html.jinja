<!DOCTYPE html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Media Card · New</title>
        <meta name="referrer" content="no-referrer" />
        <link rel="preconnect" href="https://emoji.awkchan.top" crossorigin />
        <link rel="dns-prefetch" href="https://emoji.awkchan.top" />
        <link rel="stylesheet" href="icon.css" />
        <link rel="stylesheet" href="tailwind.css" />
        {% from "macros.jinja" import render_content %}
        <style>
            body {
                font-family: "PingFang SC", sans-serif;
                background-color: #e2e8f0;
                -webkit-font-smoothing: antialiased;
                margin: 15px;
            }

            .square-img {
                aspect-ratio: 1 / 1;
                object-fit: cover;
                width: 100%;
                height: 100%;
                display: block;
            }

            .live-tag-strict {
                height: 19px;
                background-color: rgba(0, 0, 0, 0.5);
                border-radius: 2px;
                padding: 0 5px;
                display: flex;
                align-items: center;
                color: #fff;
                border: none;
                outline: none;
            }
        </style>
    </head>
    <body class="flex justify-center break-all">{{ render_content(result) }}</body>
    <script defer>
        document.addEventListener("DOMContentLoaded", function() {
            document
                .querySelectorAll(".comment .single-image")
                .forEach((img_container) => {
                    const applyStyle = () => {
                        const h = img_container.offsetHeight;
                        const w = img_container.offsetWidth;
                        if (!h || !w || !isFinite(h / w)) return;
                        const aspectRatio = h / w;
                        if (aspectRatio >= 0.9) {
                            // 竖图：限制宽度，放高
                            img_container.classList.add("max-w-36");
                        } else {
                            // 横图：限制高度，放宽
                            img_container.classList.add("max-h-36");
                        }
                    };
                    applyStyle();
                });
        });
    </script>
</html>
