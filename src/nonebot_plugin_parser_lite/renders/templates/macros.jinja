{% macro build_images(img_list) %}
{% if not img_list %}
return ""
{% endif %}

{% set count = img_list|length %}
{% set grid_class = "single" %}
{% if count == 2 %}
{% set grid_class = "double" %}
{% elif count == 4 %}
{% set grid_class = "quad" %}
{% elif count >= 3 %}
{% set grid_class = "nine" %}
{% endif %}

{% set max_visible = 9 %}
{% set visible_imgs = img_list[:max_visible] %}
{% set hidden_count = count - max_visible if count > max_visible else 0 %}

{% set items_html = [] %}
{% for src in visible_imgs %}
{% set more_html = src[1] %}
{% if hidden_count > 0 and loop.index == visible_imgs|length - 1 %}
{% set more_html = more_html + '<div class="more-count">+' + hidden_count|string + '</div>' %}
{% endif %}
{% set _ = items_html.append('<div class="image-item"><img src="' + (src[0] if src[0] else " ") + '">' + more_html + '
</div>' ) %} {% endfor %} <div class="images-container">
    <div class="images-grid {{ grid_class }}">
        {{ items_html|join('') }}
    </div>
</div>
{% endmacro %}

{% macro render_content(content) %}
{% set html_parts = [] %}
{% set current_imgs = [] %}

{% macro flush_images() %}
{% if current_imgs %}
{% set _ = html_parts.append(build_images(current_imgs)) %}
{% set current_imgs = [] %}
{% endif %}
{% endmacro %}

{% set first_text_seen = false %}
