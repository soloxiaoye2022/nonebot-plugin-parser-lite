{% set _ = current_imgs.append((src, "")) %}
{% elif cont.__class__.__name__ == 'str' %}
{% set src = cont | escape %}
{% if not first_text_seen or prev_is_sticker or next_is_sticker %}
<span class="text">{{ cont }}</span>
{% else %}
<p class="text">{{ cont }}</p>
{% endif %}
{% set first_text_seen = true %}
{% elif cont.__class__.__name__ == 'GraphicContent' %}
{% set src = cont | safe_path %}
{% set alt = cont.alt or "" %}
<div class="images-container">
    <div class="images-grid single">
        <div class="image-item">
            <img src="{{ src }}">
        </div>
    </div>
    <center><span class="text">{{ alt }}</span></center>
</div>

{% elif cont.__class__.__name__ == 'StickerContent' %}
{% set src = cont | safe_path %}
{% set size = cont.size %}
<img class="sticker {{ size }}" src="{{ src }}">
{% elif cont.__class__.__name__ == 'VideoContent' %}
{% set src = cont | safe_path("get_cover_path") %}
<div class="images-container">
    <div class="images-grid single">
        <div class="video-cover">
            <img src="{{ src }}">
            <div class="play-btn-overlay">
                <i class="fas fa-play" style="margin-left: 4px;"></i>
            </div>
        </div>
    </div>
</div>
{% endif %}

