{# 通用评论渲染片段，可在任意卡片模板中 include #}
{# 单条评论渲染宏（支持递归）#}
{% macro render_comment_item(comment, is_reply=false) %}
{% set container_class = 'reply' if is_reply else 'comment' %}
<div class="{{ container_class }}-container">
    <div class="{{ container_class }}-avatar-wrapper">
        <img src="{{ comment.author | safe_path('get_avatar_path') }}" class="{{ container_class }}-avatar">
    </div>

    <div class="{{ container_class }}-content-wrapper">
        <div class="{{ container_class }}-author-row">
            <div class="{{ container_class }}-author-info">
                <span class="{{ container_class }}-author-name">{{ comment.author.name }}</span>
            </div>
            <span class="{{ container_class }}-time">{{ comment.formatted_datetime }}</span>
        </div>
        <div class="{{ container_class }}-text">
            {{ render_content(comment.content) }}
        </div>

        <div class="comment-stats">
            {% if comment.stats.like_count %}
            <span class="comment-stat">
                <i class="fas fa-thumbs-up"></i>
                <span>{{ comment.stats.like_count }}</span>
            </span>
            {% endif %}
            {% if comment.location %}
            <span class="comment-stat">
                <i class="fas fa-map-marker-alt"></i>
                <span>{{ comment.location }}</span>
            </span>
            {% endif %}
        </div>

        {# 递归渲染回复 #}
        {% if comment.replies and comment.replies|length > 0 %}
        <div class="comment-replies">
            {% for reply in comment.replies[:5] %}
            {{ render_comment_item(reply, is_reply=true) }}
            {% endfor %}
        </div>
        {% endif %}
    </div>
</div>
{% endmacro %}

{# 主评论渲染宏 #}
{% macro render_comments(comments) %}

{% if comments and comments|length > 0 %}
<div class="comments-section">
    <div class="comments-header">
        <i class="fas fa-comments"></i> 评论 ({{ comments|length }})
    </div>

    {% for comment in comments %}
    {{ render_comment_item(comment) }}
    {% endfor %}
</div>
{% endif %}
{% endmacro %}