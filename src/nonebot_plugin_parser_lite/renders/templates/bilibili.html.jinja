<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bilibili Card</title>
    {% from "macros.jinja" import render_comments, render_content %}
    {% from "stats.jinja" import render_stats %}
    {% include "share.html" %}
    <style>
        /* 封面上的标签 */
        .type-tag {
            left: 20px;
            border-left: 3px solid var(--primary-color);
        }

        /* 作者信息与二维码区域 */
        .author-qr-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px dashed #eee;
        }

        .author-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .author-avatar {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }

        .author-details h3 {
            font-size: 19px;
            margin-bottom: 6px;
            color: var(--dark-color);
            font-weight: 700;
        }

        .author-meta {
            color: var(--gray-color);
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .info-badge {
            background-color: #f1f8ff;
            padding: 2px 8px;
            border-radius: 6px;
            font-weight: 600;
            font-family: Consolas, Monaco, monospace;
            font-size: 12px;
        }

        .info-badge.uid {
            color: var(--secondary-color);
            background-color: #eaf4fc;
        }

        .info-badge.content-id {
            color: #e67e22;
            background-color: #fdf2e9;
        }

        .time-text {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .time-text::before {
            content: "\f017";
            font-family: "Font Awesome 6 Free";
            font-weight: 400;
        }

        .qrcode-placeholder {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 4px;
            color: #ddd;
        }

        .qrcode-icon {
            font-size: 32px;
            color: #eee;
        }

        .ai-summary {
            background-color: #f8faff;
            padding: 16px 20px;
            border-radius: 10px;
            border: 1px solid #e1e8ed;
            margin-bottom: 20px;
            position: relative;
        }

        .ai-summary h4 {
            color: var(--secondary-color);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
            font-weight: 700;
        }

        .ai-summary p {
            color: #505c6b;
            font-size: 14px;
            line-height: 1.6;
            text-align: justify;
        }
    </style>
</head>

<body>

    {# === 宏定义：渲染卡片 === #}
    {% macro render_card(result, is_repost=False) %}

    {# 变量定义 #}
    {% set extra = result.extra if result.extra else {} %}
    {% set comments = result.repost.comments if is_repost else result.comments %}
    {% set platform = result.platform %}
    {% set content_id = extra.content_id %}
    {% set type_tag = extra.type_tag if extra.type_tag else "B站" %}
    {% set type_icon = extra.type_icon if extra.type_icon else "fa-brands fa-bilibili" %}
    {% set type = extra.type if extra.type else "video" %}

    <div class="card" {% if is_repost %}style="width: 100%; margin-bottom: 0;" {% endif %}>
        {% if not is_repost %}
        <div class="decorative-stripe"></div>
        {% endif %}
        <div class="content-section">
            {% if extra.type_tag %}
            <div class="tag type-tag">
                <i class="fa-solid {{ extra.type_icon }}"></i>
                <span>{{ extra.type_tag }}</span>
            </div>
            {% endif %}

            <div class="tag platform-tag">
                <img src="{{ result.platform.logo_path }}" style="height: 16px; margin-right: 6px;">
                <span>BILIBILI</span>
            </div>

            {# --- 作者信息行 --- #}
            {% if result.author %}
            <div class="author-qr-row">
                <div class="author-info">
                    <img src="{{ result.author.avatar_path or '' }}" class="author-avatar">
                    <div class="author-details">
                        <h3>{{ result.author.name }}</h3>
                        <div class="author-meta">
                            {% if result.author.id %}
                            <span class="info-badge uid">UID: {{ result.author.id }}</span>
                            {% endif %}
                            {% if content_id %}
                            <span class="info-badge content-id">{{ content_id }}</span>
                            {% endif %}
                            {% if result.formatted_datetime %}
                            <span class="time-text">{{ result.formatted_datetime }}</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="qrcode-placeholder">
                    {% if result.qr_code_path %}
                    <img src="{{ result.qr_code_path }}" alt="QR Code"
                        style="width: 77px; height: 77px; border-radius: 8px;" />
                    {% else %}
                    <i class="fas fa-qrcode qrcode-icon"></i>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            {# --- 统计数据 --- #}
            {{ render_stats(result.stats) }}
            {# --- 主要标题 --- #}
            {% if result.title %}
            <div class="title">{{ result.title }}</div>
            {% endif %}

            {# --- AI 总结 --- #}
            {% if extra.info %}
            <div class="ai-summary">
                <h4><i class="fas fa-robot"></i> AI 内容总结</h4>
                <p>{{ extra.info }}</p>
            </div>
            {% endif %}

            {# --- 正文描述 --- #}
            <div>{{ render_content(result.content) }}</div>

            {# --- 旧版 Repost (保留兼容性) --- #}
            {% if result.repost %}
            <div
                style="margin-top: 20px; border: 1px solid #eee; background-color: #fafbfc; border-radius: 8px; padding: 15px;">
                <div style="margin-bottom:10px; color:#666; font-size:14px; font-weight:600;">
                    <i class="fas fa-share" style="margin-right:5px;"></i> 转发内容
                </div>
                <div style="width: 100%; overflow: hidden;">
                    {{ render_card(result.repost, is_repost=True) }}
                </div>
            </div>
            {% endif %}
        </div>
        {# --- 评论区 --- #}
        {{ render_comments(comments) }}
        {# --- 底部 --- #}
        {% if not is_repost %}
        <div class="footer-section">
            <div class="footer-brand">
                <i class="fas fa-layer-group"></i>
                <span>{{ bot_name }} Parser || Designed By LoCCai</span>
            </div>
            <div class="footer-info">
                <i class="fas fa-clock" style="margin-right: 1px;"></i>
                <span>Rendering at {{ rendering_time }}</span>
            </div>
        </div>
        {% endif %}
    </div>
    {% endmacro %}

    {{ render_card(result) }}

</body>

</html>