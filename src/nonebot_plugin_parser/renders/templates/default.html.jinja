<!DOCTYPE html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Media Card</title>
  {% include "share.html" %}
  {% from "comments.jinja" import render_comments %}
  {% from "stats.jinja" import render_stats %}
</head>

<body>
  {% macro render_card(result, is_repost=False) %}
  <div class="card">
    {% if not is_repost %}
    <div class="decorative-stripe"></div>
    {% endif %}

    <div class="content-section">
      {# Header #} {% if result.author %}
      <div class="header">
        {% if result.author.avatar_path %}
        <img src="{{ result.author.avatar_path }}" class="avatar" alt="avatar" />
        {% endif %}
        <div class="user-info">
          <div class="username">{{ result.author.name }}</div>
          {% if result.formatted_datetime %}
          <div class="time">{{ result.formatted_datetime }}</div>
          {% endif %}
        </div>

        {# Platform Logo #}
        {% if not is_repost and result.platform and result.platform.logo_path %}
        <div class="tag platform-tag">
          <img src="{{ result.platform.logo_path }}" style="height: 16px; margin-right: 6px;">
          <span>{{ result.platform.display_name }}</span>
        </div>
        {% endif %}

        {# QR Code #}
        {% if not is_repost and result.qr_code_path %}
        <img src="{{ result.qr_code_path }}" class="qrcode" alt="QR Code"
          style="width: 40px; height: 40px; border-radius: 4px; margin-left: auto;" />
        {% endif %}
      </div>
      {% endif %}
      {# --- 统计数据 --- #}
      {{ render_stats(result.stats) }}

      {# Title #} {% if result.title %}
      <div class="title">{{ result.title }}</div>
      {% endif %}

      {# Content #}
      <div>{{ result.content | safe }}</div>
      {# Repost #} {% if result.repost %} {{
      render_card(result.repost, is_repost=True) }} {% endif %}
    </div>
    {# --- 评论区 --- #}
    {{ render_comments(result) }}
    {# --- 底部 --- #}
    {% if not is_repost %}
    <div class="footer-section">
      <div class="footer-brand">
        <i class="fas fa-layer-group"></i>
        <span>{{ bot_name }} Parser</span>
      </div>
      <div class="footer-info">
        <i class="fas fa-clock" style="margin-right: 1px;"></i>
        <span>Rendering at {{ rendering_time }}</span>
      </div>
    </div>
    {% endif %}
  </div>
  </div>
  {% endmacro %} {{ render_card(result) }}
</body>

</html>