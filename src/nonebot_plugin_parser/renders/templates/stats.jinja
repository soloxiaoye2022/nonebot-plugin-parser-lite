{# 通用统计信息渲染片段，可在任意卡片模板中 include #}
{% macro render_stats(stats) %}
{% set stat_items = [] %}

{# 按照顺序：播放 弹幕 硬币 点赞 收藏 评论 分享 #}
{# 只添加有值的统计项，没有值时不显示整个div盒子 #}

{# 播放量 #}
{% if stats.view_count and stats.view_count != '-' %}
{% set _ = stat_items.append({'key': 'play', 'value': stats.view_count, 'label': '播放', 'icon': 'fa-eye',
'color':
'#e74c3c'}) %}
{% endif %}

{# 弹幕数 #}
{% if stats.extra.danmaku and stats.extra.danmaku != '-' %}
{% set _ = stat_items.append({'key': 'danmaku', 'value': stats.extra.danmaku, 'label': '弹幕', 'icon':
'fa-comment-dots', 'color': '#3498db'}) %}
{% endif %}

{# 硬币数 #}
{% if stats.extra.coin and stats.extra.coin != '-' %}
{% set _ = stat_items.append({'key': 'coin', 'value': stats.extra.coin, 'label': '硬币', 'icon': 'fa-coins',
'color': '#f39c12'}) %}
{% endif %}

{# 点赞数 #}
{% if stats.like_count and stats.like_count != '-' %}
{% set _ = stat_items.append({'key': 'like', 'value': stats.like_count, 'label': '点赞', 'icon':
'fa-thumbs-up',
'color': '#2ecc71'}) %}
{% endif %}

{# 收藏数 #}
{% if stats.collect_count and stats.collect_count != '-' %}
{% set _ = stat_items.append({'key': 'favorite', 'value': stats.collect_count, 'label': '收藏', 'icon':
'fa-star',
'color': '#9b59b6'}) %}
{% endif %}

{# 评论数 #}
{% if stats.comment_count and stats.comment_count != '-' %}
{% set _ = stat_items.append({'key': 'reply', 'value': stats.comment_count, 'label': '评论', 'icon':
'fa-comment',
'color': '#1abc9c'}) %}
{% endif %}

{# 分享数 #}
{% if stats.share_count and stats.share_count != '-' %}
{% set _ = stat_items.append({'key': 'share', 'value': stats.share_count, 'label': '分享', 'icon': 'fa-share',
'color': '#34495e'}) %}
{% endif %}

{# 只在有统计项时显示整个统计容器 #}
{% if stat_items %}
<div class="stats-container">
    {% for item in stat_items %}
    <div class="stat-item" style="border-left-color: {{ item.color }};">
        <div class="stat-icon" style="background-color: {{ item.color }};">
            <i class="fas {{ item.icon }}"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value">{{ item.value }}</div>
            <div class="stat-label">{{ item.label }}</div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endmacro %}